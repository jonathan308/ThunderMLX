+namespace {
+Connection* emergency_connections = nullptr;
+size_t emergency_connection_count = 0;
+} // namespace
+
+void register_emergency_teardown(Connection* connections, size_t count) {
+  emergency_connections = connections;
+  emergency_connection_count = count;
+}
+
+void emergency_teardown() {
+  Connection* conns = emergency_connections;
+  size_t count = emergency_connection_count;
+  emergency_connections = nullptr;
+  emergency_connection_count = 0;
+  for (size_t i = 0; i < count; i++) {
+    Connection& c = conns[i];
+    if (c.ctx == nullptr) {
+      continue;
+    }
+    if (c.queue_pair != nullptr) {
+      ibv().destroy_qp(c.queue_pair);
+      c.queue_pair = nullptr;
+    }
+    if (c.completion_queue != nullptr) {
+      ibv().destroy_cq(c.completion_queue);
+      c.completion_queue = nullptr;
+    }
+  }
+}
