+// The RDMA driver can lose a completion under sustained load. Every polling
+// loop below used to spin forever in that case, pinning the CPU and keeping
+// Metal/RDMA memory wired until the host was rebooted. Fail the collective
+// with an exception instead once no completion has arrived for a while; the
+// caller can tear down cleanly and a supervisor can restart the job.
+// JACCL_PROGRESS_TIMEOUT_MS tunes the window (default 30000; <=0 restores the
+// legacy spin-forever behavior).
+inline int64_t progress_timeout_ms() {
+  static const int64_t timeout = []() -> int64_t {
+    const char* v = std::getenv("JACCL_PROGRESS_TIMEOUT_MS");
+    return v ? std::atoll(v) : 30000;
+  }();
+  return timeout;
+}
+
+// Collectives may be dispatched from different CPU streams (MLX maps the
+// communication stream to the caller's stream), so two threads can post to
+// and poll the SAME queue pair / completion queue concurrently. ibverbs
+// objects are not thread-safe on typical providers; a concurrent
+// ibv_poll_cq race silently loses completions, which the polling loops then
+// wait on forever. Serialize every collective on the mesh.
+inline std::mutex& collective_mutex() {
+  static std::mutex m;
+  return m;
+}
+
+// The polling loops historically ignored ibv_wc.status entirely, so error
+// completions (flushes, retry-exceeded) were processed as if successful.
+// Surface the first few so failures are diagnosable.
+inline void report_error_completions(const char* where, const ibv_wc* wc, int n) {
+  static int reported = 0;
+  for (int i = 0; i < n; i++) {
+    if (wc[i].status != IBV_WC_SUCCESS && reported < 16) {
+      std::fprintf(
+          stderr,
+          "[jaccl] %s: work completion error status=%d wr_id=0x%llx\n",
+          where,
+          static_cast<int>(wc[i].status),
+          static_cast<unsigned long long>(wc[i].wr_id));
+      std::fflush(stderr);
+      reported++;
+    }
+  }
+}
+
+class ProgressGuard {
+ public:
+  explicit ProgressGuard(const char* where)
+      : where_(where), last_(std::chrono::steady_clock::now()) {}
+
+  void progressed() {
+    last_ = std::chrono::steady_clock::now();
+  }
+
+  void check() const {
+    const int64_t timeout = progress_timeout_ms();
+    if (timeout <= 0) {
+      return;
+    }
+    auto waited = std::chrono::duration_cast<std::chrono::milliseconds>(
+                      std::chrono::steady_clock::now() - last_)
+                      .count();
+    if (waited > timeout) {
+      std::ostringstream msg;
+      msg << "[jaccl] " << where_ << " made no progress for " << waited
+          << "ms; an RDMA completion was likely lost. Failing the collective "
+             "instead of spinning forever.";
+      // Collectives may run on threads with no exception boundary, where a
+      // throw becomes std::terminate with RDMA work still outstanding —
+      // which can leave DMA-pinned pages wired until reboot. When
+      // JACCL_TIMEOUT_ACTION=teardown-exit, cancel the RDMA state first and
+      // exit with a distinct status a supervisor can treat as restartable.
+      const char* action = std::getenv("JACCL_TIMEOUT_ACTION");
+      if (action != nullptr &&
+          std::string_view(action) == "teardown-exit") {
+        std::fprintf(stderr, "%s\n", msg.str().c_str());
+        std::fflush(stderr);
+        emergency_teardown();
+        std::_Exit(75); // EX_TEMPFAIL: restartable failure
+      }
+      throw std::runtime_error(msg.str());
+    }
+  }
+
+ private:
+  const char* where_;
+  std::chrono::steady_clock::time_point last_;
+};
