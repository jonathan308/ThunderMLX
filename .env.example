# MiniMax-M3 MLX cluster local configuration.
# Copy this file to .env.local on the primary Mac and fill in your machine values.
# Do not commit .env.local.

# Project location on both machines. Defaults to the directory containing scripts.
# M3_CLUSTER_DIR=/Users/you/minimax-m3-cluster

# Model path or Hugging Face id. A local path is recommended for offline startup.
# You can edit this in the dashboard Settings tab, then restart the cluster.
MLX_M3_MODEL=mlx-community/MiniMax-M3-4bit
MLX_M3_MODEL_ID=mlx-community/MiniMax-M3-4bit

# Rank labels shown in the dashboard.
M3_RANK0_LABEL="Primary Mac"
M3_RANK1_LABEL="Worker Mac"

# SSH control plane. Use a direct Thunderbolt address/hostname when possible.
# Include a username if your SSH config does not supply one, e.g. user@worker.local.
M3_RANK1_DIRECT_SSH=worker.local
# Optional fallback such as a VPN hostname. Leave blank if not used.
M3_RANK1_FALLBACK_SSH=
# Optional explicit peer used by dashboard/stop/sync. Defaults to direct, then fallback.
M3_PEER=
# Optional SSH identity.
M3_SSH_KEY=

# Data plane for MLX distributed communication.
M3_RANK0_DATA_IP=primary.local
M3_RANK1_DATA_IP=worker.local
M3_RANK0_RDMA=
M3_RANK1_RDMA=
M3_MLX_BACKEND=jaccl

# API and dashboard.
MLX_M3_HOST=0.0.0.0
MLX_M3_PORT=8080
M3_GUI_HOST=0.0.0.0
M3_GUI_PORT=8090
# Trusted-network dashboard access, for example Tailscale.
# Set M3_GUI_HOST=0.0.0.0 and advertise one of these.
M3_GUI_PUBLIC_HOST=
M3_GUI_PUBLIC_URL=
M3_OMLX_PORT=8000
M3_PUBLIC_BASE_URL=http://primary.local:8080/v1

# Optional combined gateway. Clients can point here to see both ThunderMLX M3
# and oMLX models through one OpenAI-compatible /v1 surface.
M3_GATEWAY_HOST=0.0.0.0
M3_GATEWAY_PORT=8010
M3_GATEWAY_PUBLIC_BASE_URL=http://primary.local:8010/v1
M3_GATEWAY_M3_BASE_URL=http://127.0.0.1:8080
M3_GATEWAY_OMLX_BASE_URL=http://127.0.0.1:8000
M3_GATEWAY_M3_MODEL_IDS=Minimax-M3,Minimax-M3-No-Think,M3-Web
M3_GATEWAY_CLAUDE_MODEL_IDS=Claude-Code,Claude-Code-Sonnet
M3_GATEWAY_CLAUDE_CLI=/Users/you/.local/bin/claude
M3_GATEWAY_CLAUDE_MODEL=sonnet
M3_GATEWAY_CLAUDE_PERMISSION_MODE=dontAsk
M3_GATEWAY_CLAUDE_WORKDIR=/Users/you
M3_GATEWAY_CLAUDE_TIMEOUT_SECONDS=7200
M3_GATEWAY_AUTO_SWITCH=1
M3_GATEWAY_ALLOW_START_M3=1
M3_GATEWAY_ALLOW_STOP_M3=1
M3_GATEWAY_ALLOW_UNLOAD_OMLX=1
M3_GATEWAY_SWITCH_TIMEOUT_SECONDS=900
# SSE comments keep streaming clients alive during long prefill and buffered
# tool-call validation. Set 0 to disable transport-level keepalives.
M3_GATEWAY_SSE_KEEPALIVE_SECONDS=5
# Context window advertised on the gateway's /v1/models. The backend supports
# 1M natively, but 300k keeps Codex/Claude Code shims compacting early enough
# for stable long agent runs (recommended coding window is 262k-512k).
M3_GATEWAY_ADVERTISED_MAX_MODEL_LEN=300000
# Extra oMLX unload endpoints, comma-separated, if your oMLX build uses custom
# model unload routes. The gateway also auto-unloads loaded oMLX models exposed
# by /admin/api/models when switching back to M3.
M3_GATEWAY_OMLX_UNLOAD_URLS=

# Sharding. For MiniMax-M3, the total layer count is 60.
M3_SHARDING_MODE=pipeline
M3_PIPELINE_LAYERS=38,22

# Generation defaults.
MLX_M3_DEFAULT_MAX_TOKENS=16384
# Text-only non-stream requests without explicit max_tokens use this safer cap.
MLX_M3_NONSTREAM_DEFAULT_MAX_TOKENS=512
# Used only when OpenWebUI omits max_tokens. Agents can still request more explicitly.
MLX_M3_OPENWEBUI_DEFAULT_MAX_TOKENS=2048
MLX_M3_DEFAULT_TEMPERATURE=0.2
MLX_M3_DEFAULT_TOP_P=1.0
MLX_M3_DEFAULT_TOP_K=0
MLX_M3_DEFAULT_MIN_P=0.0
MLX_M3_TOOL_DEFAULT_TEMPERATURE=0
MLX_M3_TOOL_DEFAULT_TOP_P=1.0
MLX_M3_TOOL_DEFAULT_TOP_K=0
MLX_M3_TOOL_DEFAULT_MIN_P=0.0
# Preserve the requested model's thinking mode for tools by default.
# Set to enabled only if you want to force MiniMax's interleaved thinking tool path.
MLX_M3_TOOL_THINKING_MODE=request
MLX_M3_EMIT_TOOL_REASONING=1
# Native mode streams reasoning and ordinary content while retaining a short
# marker holdback so MiniMax tool XML never reaches SSE clients. Full-turn
# buffering is available only for the optional compatibility retry layer.
MLX_M3_TOOL_STREAM_BUFFER_ALL=0
MLX_M3_TOOL_STREAM_CONTENT=1
# Native mlx-vlm MiniMax parsing is the production default. Enable this only
# when deliberately testing legacy malformed-output recovery and retries.
MLX_M3_TOOL_COMPAT_OVERLAY=0
MLX_M3_TOOL_SYSTEM_HINT=0
# If an explicit native action ends after reasoning but before a tool call,
# append one cache-friendly continuation using the same native thinking mode.
# Successful calls and ordinary chat never enter this path.
MLX_M3_NATIVE_TOOL_ACTION_RETRY_ATTEMPTS=1
# Above this prompt length, a malformed native tool turn releases only its
# active RAM KV before retrying. The last valid SSD checkpoint is preserved
# and rehydrated, avoiding a second live graph on memory-constrained ranks.
MLX_M3_NATIVE_TOOL_ACTION_RETRY_RAM_RESET_TOKENS=65536
# Privacy-sensitive local parser forensics. When enabled, suspicious native
# Write calls can store the raw model response under ignored ops/logs/ files.
MLX_M3_TOOL_PARSE_DIAGNOSTICS=0
# Inject a daily-stable local date unless the client already supplies
# authoritative date/time metadata. The prompt changes only at midnight.
MLX_M3_INJECT_DATE_CONTEXT=1
# These controls also bound the single native action continuation above; the
# remaining compatibility retry ladder applies only with the overlay enabled.
MLX_M3_TOOL_UNUSABLE_RETRY_ATTEMPTS=3
MLX_M3_TOOL_UNUSABLE_RETRY_TEMPERATURES=0.2,0.3
# Cap each retry's decode budget. Valid tool calls stop decode early, so this
# only bounds pathological thinking rambles (which are also the longest, most
# wedge-prone hot-suffix decodes).
MLX_M3_TOOL_UNUSABLE_RETRY_MAX_TOKENS=16384
# A final no-thinking retry can rescue malformed thinking output on short
# prompts. Never switch templates above this token count because doing so
# invalidates the hot prefix and forces a hidden full-context prefill.
MLX_M3_TOOL_RETRY_NO_THINK=1
MLX_M3_TOOL_RETRY_NO_THINK_MAX_PROMPT_TOKENS=16384
# Preserve native atomic Write/Edit behavior by default. Set both values above
# zero only when a client explicitly requires staged scaffold writes. Partial
# calls remain non-executable and are bounded by the token ceiling below.
MLX_M3_TOOL_WRITE_CHUNK_MAX_CHARS=0
MLX_M3_TOOL_WRITE_CHUNK_TARGET_CHARS=0
# Safety ceiling only for a tool block that opened but never closed. Complete
# calls and normal assistant output are not capped by this setting.
MLX_M3_TOOL_INCOMPLETE_CALL_TOKEN_BUDGET=32768
MLX_M3_TOOL_DETOKENIZER_SILENT_TOKEN_BUDGET=64
MLX_M3_TOOL_THINKING_RUNAWAY_TOKEN_BUDGET=0
MLX_M3_TOOL_NO_CALL_TOKEN_BUDGET=0
MLX_M3_TOOL_ACTION_NO_CALL_TOKEN_BUDGET=0
# Legacy no-thinking repairs can use this focused budget when the compatibility
# overlay is enabled. Native turns do not use semantic no-call caps.
MLX_M3_TOOL_RETRY_NO_CALL_TOKEN_BUDGET=384
MLX_M3_BATCH_TOOL_NATURAL_DRAIN=1
# Break pathological agent loops: after N byte-identical tool commands with no
# visible assistant text since the last user message, drop tools for one turn
# so the model must answer from gathered results. 0 disables.
MLX_M3_TOOL_LOOP_FORCE_FINAL_REPEATED_COMMANDS=10
# End an agent turn sooner when the exact same command also returns the exact
# same result repeatedly. Unlike the broad command counter above, productive
# test reruns remain allowed when their output changes.
MLX_M3_TOOL_LOOP_FORCE_FINAL_IDENTICAL_COMMAND_RESULTS=4
# Keep the native tool schema stable across turns. Exact completed duplicate
# mutations are rejected at the response boundary without hiding any tool.
MLX_M3_TOOL_LOOP_FILTER_REPEATED_WORK_TOOLS=
# Optional targeted breaker for evidence-gathering loops. This does not cap
# normal coding tools; only listed tools are forced to synthesize after N
# repeated calls without a visible assistant response.
MLX_M3_TOOL_LOOP_FORCE_FINAL_REPEATED_TOOL_COUNT=8
MLX_M3_TOOL_LOOP_FORCE_FINAL_REPEATED_TOOL_NAMES=web_search
MLX_M3_DEFAULT_REPETITION_PENALTY=0
MLX_M3_DEFAULT_PRESENCE_PENALTY=0
MLX_M3_DEFAULT_FREQUENCY_PENALTY=0
MLX_M3_THINKING_MODE=enabled
MLX_M3_THINKING_BUDGET=0
MLX_M3_ALLOW_THINKING_BUDGET=0
MLX_M3_IMAGE_DEFAULT_MAX_TOKENS=768
MLX_M3_IMAGE_MAX_TOKENS=0

# Stability/performance defaults. Tune after a baseline stress test.
MLX_M3_STREAM_MODE=buffered
MLX_M3_MAX_CONCURRENT_REQUESTS=1
MLX_M3_REQUEST_HISTORY_MAX=32
MLX_M3_DECODE_EVAL_EVERY=4
MLX_M3_DECODE_EVAL_AFTER_TOKENS=96
MLX_M3_DECODE_EVAL_AFTER_EVERY=1
MLX_M3_THINKING_DECODE_EVAL_EVERY=1
MLX_M3_THINKING_RAW_SILENT_LIMIT=32
MLX_M3_LONG_CONTEXT_DECODE_EVAL_TOKENS=24576
MLX_M3_LONG_CONTEXT_DECODE_EVAL_EVERY=1
MLX_M3_ADAPTIVE_LONG_CONTEXT_DECODE_EVAL=0
MLX_M3_MID_CONTEXT_DECODE_EVAL_TOKENS=24576
MLX_M3_MID_CONTEXT_DECODE_EVAL_EVERY=1
MLX_M3_HIGH_CONTEXT_DECODE_EVAL_TOKENS=98304
MLX_M3_HIGH_CONTEXT_DECODE_EVAL_EVERY=1
MLX_M3_ALLOW_UNSAFE_RUNTIME_TUNING=0
MLX_M3_REFRESH_GENERATION_STREAM=0
MLX_M3_SYNC_SAMPLED_TOKENS=1
MLX_M3_RANK0_ONLY_LOGITS=1
MLX_M3_RANK0_DECODE_OWNER=1
MLX_M3_ENABLE_UNSAFE_INFLIGHT_STOP=1
MLX_M3_STOP_ON_CLIENT_DISCONNECT=1
MLX_M3_STOP_CHECK_EVERY=4
# 0 disables normal-request distributed prefill polling; /v1/stop still uses
# the per-rank stop-file path for fast cancellation without slowing MSA prefill.
MLX_M3_PREFILL_STOP_CHECK_EVERY=1
MLX_M3_PREFILL_STOP_FILE=/private/tmp/minimax_m3_prefill_stop_requested
MLX_M3_SSE_KEEPALIVE_SECONDS=5
# The server emits both an SSE comment and an empty OpenAI delta at this cadence
# so transport-level and parsed-event idle timers remain active.
# Emit a lower-frequency visible status while a buffered tool action is still
# being recovered.
MLX_M3_TOOL_STREAM_PROGRESS_SECONDS=45
MLX_M3_RANK1_IDLE_SLEEP_SECONDS=0.01
MLX_M3_PREFILL_STEP_SIZE=4096
# Keep 4096 for normal prompt processing speed, but drop to a smaller chunk
# above this prompt length to avoid high-context distributed prefill stalls.
# Set MLX_M3_ADAPTIVE_PREFILL_STEP_TOKENS=0 to disable the adaptive lane.
MLX_M3_ADAPTIVE_PREFILL_STEP_TOKENS=262144
MLX_M3_ADAPTIVE_PREFILL_STEP_SIZE=2048
# Depth-2 chunked-prefill overlap (docs/DESIGN-chunk-overlap-native.md); keep 0 until certified.
MLX_M3_PREFILL_OVERLAP_NATIVE=0
MLX_MAX_OPS_PER_BUFFER=16
MLX_MAX_MB_PER_BUFFER=512
MLX_M3_PREFILL_CLEAR_CACHE_EVERY=0
MLX_M3_MAX_KV_SIZE=1000000
# Advertise an operational coding window below the native maximum so agent
# clients compact before an asymmetric worker runs out of unified memory.
MLX_M3_ADVERTISED_MAX_MODEL_LEN=300000
# Optional measured safety ceiling for input tokens. Zero disables enforcement;
# set per deployment after long-context validation. The server returns a normal
# OpenAI context_length_exceeded error and never silently trims tool history.
MLX_M3_HARD_MAX_INPUT_TOKENS=0
MLX_M3_KV_QUANT_ENABLED=0
MLX_M3_KV_BITS=4
MLX_M3_KV_GROUP_SIZE=64
MLX_M3_KV_QUANT_SCHEME=uniform
MLX_M3_QUANTIZED_KV_START=5000
MLX_M3_PROMPT_CACHE=1
MLX_M3_PROMPT_CACHE_THINKING=1
MLX_M3_PROMPT_CACHE_THINKING_MODE=visible
MLX_M3_PROMPT_CACHE_DIRECT_SUFFIX_IDS=0
MLX_M3_PROMPT_CACHE_MIN_REUSE=32
MLX_M3_PROMPT_CACHE_MIN_SUFFIX_TOKENS=128
MLX_M3_PROMPT_CACHE_FAST_MIN_SUFFIX_TOKENS=1
MLX_M3_PROMPT_CACHE_FAST_THINKING_MIN_SUFFIX_TOKENS=64
MLX_M3_PROMPT_CACHE_REUSE_BUCKET_TOKENS=0
MLX_M3_REASONING_RECALL=1
MLX_M3_REASONING_RECALL_MAX_SESSIONS=16
MLX_M3_REASONING_RECALL_MAX_ITEMS=64
MLX_M3_REASONING_RECALL_MAX_CHARS=65536
# 20 min: release the idle RAM cache so wired memory drops between work
# sessions (3h retention pinned a 256GB host at high pressure under heavy
# multi-session days; the SSD cache makes re-warm cheap).
MLX_M3_PROMPT_CACHE_TTL_SECONDS=1200
MLX_M3_PROMPT_CACHE_MAX_TOKENS=0
MLX_M3_PROMPT_CACHE_GENERATED_REUSE_MAX_TOKENS=4096
MLX_M3_PROMPT_CACHE_PROTECT_LARGE=1
MLX_M3_PROMPT_CACHE_PROTECT_MIN_TOKENS=32768
MLX_M3_PROMPT_CACHE_PROTECT_BYPASS_MAX_TOKENS=8192
MLX_M3_PROMPT_CACHE_SESSION_PROTECT=1
MLX_M3_PROMPT_CACHE_SESSION_PROTECT_MIN_TOKENS=256
MLX_M3_PROMPT_CACHE_SESSION_PROTECT_BYPASS_MAX_TOKENS=8192
MLX_M3_PROMPT_CACHE_STATIC_PREFIX_REBUILD_MAX_TOKENS=512
MLX_M3_PROMPT_CACHE_STATIC_PREFIX_REBUILD_MAX_REUSE_RATIO=0.80
MLX_M3_PROMPT_CACHE_SMALL_THINKING_REBUILD_MAX_TOKENS=0
MLX_M3_PROMPT_CACHE_SMALL_THINKING_REBUILD_MAX_SUFFIX_TOKENS=0
MLX_M3_PROMPT_CACHE_SESSION_MAP_MAX=16
# 2 resident session caches is the stability sweet spot: covers two
# alternating agent clients at instant TTFT without pinning wired memory.
MLX_M3_PROMPT_CACHE_RESIDENT_SLOTS=1
MLX_M3_PROMPT_CACHE_RESIDENT_MAX_TOTAL_TOKENS=750000
MLX_M3_PROMPT_CACHE_SSD=0
MLX_M3_PROMPT_CACHE_SSD_RESTORE=0
MLX_M3_PROMPT_CACHE_SSD_AUTO_SAVE=0
# Avoid rewriting a large distributed KV checkpoint after every tiny turn.
# Manual saves are never throttled; successful restores seed this anchor.
MLX_M3_PROMPT_CACHE_SSD_AUTO_SAVE_MIN_DELTA_TOKENS=8192
# Restore a small append window instead of reserving the request's entire max
# output on every KV layer. Optional rank overrides let a lower-memory worker
# retain less spare capacity without changing cache offsets or model sharding.
MLX_M3_PROMPT_CACHE_SSD_APPEND_RESERVE_TOKENS=4096
MLX_M3_PROMPT_CACHE_SSD_APPEND_RESERVE_TOKENS_RANK0=
MLX_M3_PROMPT_CACHE_SSD_APPEND_RESERVE_TOKENS_RANK1=
# The cancellable batch path uses the same bounded policy when converting a
# warm cache. Keep these equal to the SSD restore reserve unless profiling a
# machine with more or less unified-memory headroom.
MLX_M3_BATCH_APPEND_RESERVE_TOKENS=4096
MLX_M3_BATCH_APPEND_RESERVE_TOKENS_RANK0=
MLX_M3_BATCH_APPEND_RESERVE_TOKENS_RANK1=
# Zero stores only logical KV contents on SSD. Restore recreates the bounded
# append window, so temporary live-cache growth does not become permanent disk
# or unified-memory capacity.
MLX_M3_PROMPT_CACHE_SSD_SAVE_RESERVE_TOKENS=0
MLX_M3_PROMPT_CACHE_SSD_SAVE_RESERVE_TOKENS_RANK0=
MLX_M3_PROMPT_CACHE_SSD_SAVE_RESERVE_TOKENS_RANK1=
MLX_M3_PROMPT_CACHE_SSD_DIR=~/.cache/thundermlx/prompt-kv
# Optional per-rank SSD roots. Leave blank to use MLX_M3_PROMPT_CACHE_SSD_DIR
# on each machine. Rank 1 often has the larger shard, so a large worker SSD is
# useful here. To store both ranks on one device, mount that device on both
# Macs and set both rank paths to that mounted filesystem.
MLX_M3_PROMPT_CACHE_SSD_DIR_RANK0=
MLX_M3_PROMPT_CACHE_SSD_DIR_RANK1=
MLX_M3_PROMPT_CACHE_SSD_TTL_SECONDS=432000
MLX_M3_PROMPT_CACHE_SSD_MAX_BYTES=429496729600
MLX_M3_PROMPT_CACHE_SSD_MIN_TOKENS=8192
MLX_M3_PROMPT_CACHE_SSD_STATUS_SCAN_INTERVAL_SECONDS=10
MLX_M3_PROMPT_CACHE_SSD_SAVE_REASONING=0
MLX_M3_PROMPT_CACHE_SSD_PRIVACY=local
MLX_M3_PROMPT_CACHE_KEEPWARM=0
MLX_M3_PROMPT_CACHE_KEEPWARM_MODE=metal
# 10s ticks keep GPU clocks ramped (gap-independent TTFT) at ~1/5 the churn
# of aggressive settings; sub-5s intervals + big resident caches can starve
# the host UI.
MLX_M3_PROMPT_CACHE_KEEPWARM_INTERVAL_SECONDS=10
MLX_M3_PROMPT_CACHE_KEEPWARM_IDLE_AFTER_SECONDS=10
MLX_M3_PROMPT_CACHE_KEEPWARM_MATRIX_SIZE=1
MLX_M3_PROMPT_CACHE_KEEPWARM_LARGE_CACHE_TOKENS=8192
MLX_M3_PROMPT_CACHE_KEEPWARM_LARGE_INTERVAL_SECONDS=5
MLX_M3_PROMPT_CACHE_KEEPWARM_SLOW_BACKOFF_SECONDS=0
MLX_M3_PROMPT_CACHE_REQUEST_START_KEEPWARM=0
MLX_M3_PROMPT_CACHE_REQUEST_START_KEEPWARM_IDLE_SECONDS=2
MLX_M3_PROMPT_CACHE_REQUEST_START_KEEPWARM_MATRIX_SIZE=128
MLX_M3_PROMPT_CACHE_REQUEST_START_KEEPWARM_REPEATS=1
MLX_M3_PROMPT_CACHE_POST_RESPONSE_KEEPWARM=0
MLX_M3_PROMPT_CACHE_POST_RESPONSE_KEEPWARM_DELAY_SECONDS=5
MLX_M3_PROMPT_CACHE_POST_RESPONSE_KEEPWARM_MATRIX_SIZE=128
MLX_M3_PROMPT_CACHE_POST_RESPONSE_KEEPWARM_REPEATS=1
MLX_M3_CLEAR_CACHE_AFTER_REQUEST=1
MLX_M3_CLEAR_CACHE_AFTER_ERROR=1
MLX_M3_VISIBLE_TRANSCRIPT_PREWARM=1
MLX_M3_VISIBLE_TRANSCRIPT_PREWARM_BLOCKING=1
MLX_M3_VISIBLE_TRANSCRIPT_PREWARM_MIN_GENERATED=1
MLX_M3_VISIBLE_TRANSCRIPT_PREWARM_MAX_TOKENS=8192
MLX_M3_VISIBLE_TRANSCRIPT_PREWARM_MAX_SUFFIX_TOKENS=4096
MLX_M3_VISIBLE_TRANSCRIPT_PREWARM_MAX_GENERATED_TOKENS=4096
MLX_M3_MAX_TOKENS_CEILING=16384
MLX_M3_KV_CACHE_STEP=4096
MLX_M3_LAYER_EVAL_EVERY=0
MLX_M3_OMLX_MINIMAX_OVERLAY=1
# Prefill-only MSA overlay (2026-07-08): "MSA Support/" ships the native
# mlx-vlm 0.6.4 MiniMax-M3 model plus ONE addition — a fused blockwise-sparse
# PREFILL fast path (msa.py kernels). Decode always runs the native path
# byte-for-byte (the earlier full overlay's replaced decode dispatch froze at
# the first mid-decode KV_CACHE_STEP boundary). Kill switch: MSA_PREFILL=0
# keeps the overlay mounted but runs pure-native prefill too.
MLX_M3_MSA_PREFILL=1
# Blockwise top-k builder tuning:
# chunk 32 + engage blockwise from 4k context. Defaults without these: 2/32768.
MLX_M3_MSA_PREFILL_BLOCKWISE_TOPK_BLOCK_CHUNK=32
MLX_M3_MSA_PREFILL_BLOCKWISE_TOPK_MIN_KV_LEN=4096
# Optional stability guard for small incremental suffixes over long resident
# caches. 0 disables it; the two-rank reference setup guards L<=512 at 32k+
# KV after captured stalls at L=194 and L=483. Large/cold prefill remains on
# the accelerated blockwise MSA path.
MLX_M3_MSA_PREFILL_LONG_K_SMALL_L_MAX_L=512
MLX_M3_MSA_PREFILL_LONG_K_SMALL_L_MIN_KV=32768
# Batch-path prefill cancel cadence: the /v1/stop check all_sum is launched
# async and read one chunk later (overlaps compute). 1 = check every chunk
# (recommended; ~zero cost with the async read), N = every Nth, 0 = never.
MLX_M3_PREFILL_CANCEL_EVERY=1
# Keep the input-prefix KV when a stream is cancelled (client disconnect or
# /v1/stop) instead of dropping the whole cache. Agent clients that retry the
# same conversation after a timeout then reuse the full prefix (instant TTFT)
# instead of re-prefilling everything. 0 restores the old full reset.
MLX_M3_KEEP_CACHE_ON_CANCEL=1
MLX_M3_DISABLE_SPARSE_INDEX=0
MLX_M3_KERNEL_STATS=0
MLX_M3_MSA_K1_IMPL=auto
# A/B selector for the BQ64 + compact-grid long-context prefill lane.
MLX_M3_MSA_K1_LONG_CONTEXT_AUTO=1
# Total KV length where the long-context lane begins; tune only with a
# repeatable 80k/100k boundary benchmark on the target hardware.
MLX_M3_MSA_K1_LONG_CONTEXT_MIN_TOTAL_K=65536
# Sparse decode speed profile:
#   16 = stability default, 2,048 selected KV tokens per sparse layer
#   8  = speed-lab setting; retest long decode before production use
#   4  = aggressive speed lab setting; validate quality at your context length
#   0  = native MiniMax behavior
MLX_M3_SPARSE_TOPK_BLOCKS_OVERRIDE=16
MLX_M3_COMPACT_DECODE_SORT_TOPK=0
# Long-context decode speed profile. Reuses sparse decode block choices for
# adjacent generated tokens. Reference 38/22 TB5 cluster evidence: 48 restored
# the fastest validated hot-decode setting while preserving stability.
MLX_M3_DECODE_TOPK_REUSE_TOKENS=48
# Tool-bearing requests use exact sparse block selection for argument fidelity;
# ordinary chat restores the faster value above immediately after each turn.
MLX_M3_TOOL_DECODE_TOPK_REUSE_TOKENS=0
MLX_M3_USE_DIRECT_DECODE_KERNEL=0
MLX_M3_DIRECT_DECODE_EVAL_MODE=small

# Memory/watchdog guardrails. Set wired/cache limits for your own hardware.
MLX_M3_WIRED_LIMIT_GB=0
MLX_M3_WIRED_LIMIT_GB_RANK0=0
MLX_M3_WIRED_LIMIT_GB_RANK1=0
MLX_M3_MEMORY_LIMIT_GB=0
MLX_M3_CACHE_LIMIT_GB=32
# Optional host-level macOS tuning. Leave off for portable/public installs.
# Enable only on dedicated inference machines after choosing values appropriate
# for each Mac's unified-memory size.
M3_ENABLE_PERFORMANCE_TUNE=0
M3_ENABLE_MACOS_NOISE_REDUCTION=0
M3_RANK0_IOGPU_WIRED_LIMIT_MB=0
M3_RANK1_IOGPU_WIRED_LIMIT_MB=0
M3_WATCHDOG_TIMEOUT=2400
M3_WATCHDOG_PREFILL_TIMEOUT=3600
M3_WATCHDOG_DECODE_TIMEOUT=180
M3_MAX_GENERATION_SECONDS=7200
M3_STOP_DRAIN_SECONDS=960
M3_FORCE_KILL=0
M3_MAX_QUICK_FAILURES=3
M3_QUICK_FAILURE_WINDOW=120
M3_RESTART_BACKOFF_INITIAL=15
M3_RESTART_BACKOFF_MAX=300
M3_API_GUARD_INTERVAL_SECONDS=15
M3_API_GUARD_START_GRACE_SECONDS=180
M3_API_DOWN_GUARD_SECONDS=75
M3_ACTIVE_NO_START_GUARD_SECONDS=120
# The no-first-token guard scales for large contexts: base for short prompts,
# margin + prompt_tokens/context_tps for long prompts, capped at max. Before a
# forced teardown it requests distributed /v1/stop and waits for clean drain.
M3_ACTIVE_NO_START_CONTEXT_TPS=1000
M3_ACTIVE_NO_START_MARGIN_SECONDS=120
M3_ACTIVE_NO_START_MAX_SECONDS=900
M3_ACTIVE_NO_START_DRAIN_SECONDS=600
M3_GUARD_TERM_GRACE_SECONDS=120
M3_SIGNAL_CLEAR_TIMEOUT=60
# Optional guard for long-lived mlx.launch parent RSS growth. 0 disables it.
# When enabled, the auto-restart supervisor recycles the cluster only after the
# API is healthy/idle and the launcher RSS remains above the limit for the grace
# period. This does not change the prompt-cache TTL; it is a process-level
# hygiene guard for distributed launcher/runtime memory.
M3_LAUNCHER_RSS_GUARD_GB=0
M3_LAUNCHER_RSS_GUARD_INTERVAL_SECONDS=300
M3_LAUNCHER_RSS_GUARD_IDLE_GRACE_SECONDS=600
M3_WARMUP_ON_START=1
M3_WARMUP_METAL=1
M3_WARMUP_METAL_SIZE=64
M3_WARMUP_METAL_REPEATS=1
M3_WARMUP_MODELS=Minimax-M3-No-Think,Minimax-M3
M3_WARMUP_INTERACTIVE_MODEL=Minimax-M3
M3_WARMUP_INTERACTIVE_PROMPTS="Hello. Reply in one short sentence.||Say one short friendly sentence about cache reuse.||Give one concise sentence about distributed MiniMax inference now."
M3_WARMUP_MAX_TOKENS=96
M3_WARMUP_TIMEOUT_SECONDS=300
M3_WARMUP_RESET_PROMPT_CACHE=0
M3_WARMUP_OPENWEBUI_SIM=1
M3_WARMUP_OPENWEBUI_SIM_TURNS=4
M3_WARMUP_OPENWEBUI_SIM_MAX_TOKENS=48

# Clean-memory preflight thresholds for stop/overnight tooling. Tune for your
# hardware, but keep them positive if you want m3_overnight_runner.py to start.
M3_ORPHAN_RANK0_WIRED_GB=30
M3_ORPHAN_RANK1_WIRED_GB=20

# Optional Hugging Face/cache behavior.
HF_HUB_OFFLINE=1
# Honor the Anthropic/Claude model selection. When false, a failed thinking
# tool turn can still retry on the small/no-thinking model via the separate
# M3_GATEWAY_ANTHROPIC_RETRY_SMALL_ON_EMPTY_TOOL fallback.
M3_GATEWAY_ANTHROPIC_ROUTE_ALIASED_TO_SMALL=0
